# Porta do servidor (Fly.io define automaticamente em produção)
PORT=3000

# Ambiente. Deixe em "development" localmente; em produção, use "production".
NODE_ENV=development

# Segredo de assinatura dos cookies de sessão. Em produção, gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=troque-este-segredo-em-producao

# Diretorio onde content.json e content-history.jsonl sao salvos.
# Local: deixe em branco (usa backend/data). Em Fly.io, use /data (volume persistente).
# DATA_DIR=

# Webhook do n8n que recebe os envios do formulario de contato.
# A URL fica somente no backend; o site publico chama /api/contact.
N8N_CONTACT_WEBHOOK_URL=

# === Autenticação ===
# Modo multi-usuário (recomendado): lista "usuario:bcrypt_hash" separada por vírgula.
# Gere os hashes com:
#   npm run hash -- senhaDoUsuario
# Exemplo:
# ADMIN_USERS=pastor:$2a$10$abc...,secretaria:$2a$10$xyz...
ADMIN_USERS=

# Modo legado (compatibilidade): senha única em texto. Só é usado se ADMIN_USERS estiver vazio.
ADMIN_PASSWORD=ipab2026
